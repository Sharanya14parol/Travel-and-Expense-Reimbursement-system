{
  "name": "travel_expense_app",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "scripts": {
    "start": "cds-serve",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "cds build --production",
    "watch-travel_requests": "cds watch --open travelrequests/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employees": "cds watch --open employees/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-expense_policies": "cds watch --open expensepolicies/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-expense_claims": "cds watch --open expenseclaims/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-finance_advance_approval": "cds watch --open financeadvanceapproval/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-employee_dashboard": "cds watch --open employeedashboard/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-finance_expense_approval": "cds watch --open financeexpenseapproval/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds": "^9.8.4",
    "@sap/xssec": "^4.13.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "workspaces": [
    "app/*"
  ],
  "_comment": "CAP project configuration with SQLite for local persistence",
  "cds": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "dummy"
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  },
  "sapux": [
    "app/travel_requests",
    "app/employees",
    "app/expense_policies",
    "app/expense_claims",
    "app/project1",
    "app/finance_advance_approval",
    "app/employee_dashboard",
    "app/finance_expense_approval"
  ]
}
