{
  "name": "expense_claims",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap/ux-ui5-tooling": "^1.23.0",
    "@ui5/cli": "^4.0.33",
    "ui5-task-zipper": "^3"
  },
  "scripts": {
    "build": "ui5 build --clean-dest",
    "postbuild": "cd dist && zip -r ../expense_claims.zip .",
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "start": "ui5 serve"
  }
}
